<header class="topbar">
  <div class="topbar-left">
    <button class="sidebar-toggle-btn d-lg-none" id="sidebarOpen">
      <i class="bi bi-list"></i>
    </button>
    <div class="topbar-breadcrumb">
      <span class="breadcrumb-base">Margyn</span>
      <i class="bi bi-chevron-right"></i>
      <span class="breadcrumb-current">{{title}}</span>
    </div>
  </div>
  <div class="topbar-right">
    <div class="topbar-search">
      <i class="bi bi-search"></i>
      <input type="text" placeholder="Search products, SKUs…" class="search-input" />
      <kbd>⌘K</kbd>
    </div>
    <button class="topbar-icon-btn theme-toggle" id="themeToggle" title="Toggle light/dark mode">
      <i class="bi bi-moon-fill" id="themeIcon"></i>
    </button>
    <button class="topbar-icon-btn" title="Notifications">
      <i class="bi bi-bell"></i>
      <span class="notif-dot"></span>
    </button>
    <button class="topbar-icon-btn" title="Refresh data">
      <i class="bi bi-arrow-clockwise" id="refreshBtn"></i>
    </button>
    <div class="topbar-last-sync">
      <i class="bi bi-circle-fill text-success" style="font-size:6px"></i>
      <span>Live</span>
    </div>
  </div>
</header>
